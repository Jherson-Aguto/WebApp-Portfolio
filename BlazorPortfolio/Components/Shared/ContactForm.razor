@rendermode InteractiveServer
@inject ContentService Svc

@if (messageSent)
{
    <div class="alert-success">
        <span class="alert-icon"><Icon Name="check-circle" Size="22" /></span>
        <div>
            <strong>Message sent!</strong>
            <p>Thanks for reaching out. I'll get back to you soon.</p>
        </div>
    </div>
}
else
{
    <EditForm Model="hiringMsg" OnValidSubmit="SendMessage" class="contact-form">
        <DataAnnotationsValidator />
        <ValidationSummary class="validation-summary" />
        <div class="form-row">
            <div class="form-group">
                <label>Name</label>
                <InputText @bind-Value="hiringMsg.Name" class="form-control" placeholder="Your name (optional)" />
            </div>
            <div class="form-group">
                <label>Email *</label>
                <InputText @bind-Value="hiringMsg.Email" class="form-control" placeholder="your@email.com" />
                <ValidationMessage For="() => hiringMsg.Email" />
            </div>
        </div>
        <div class="form-group">
            <label>Subject *</label>
            <InputText @bind-Value="hiringMsg.Subject" class="form-control" placeholder="e.g. Full Stack Developer Opportunity" />
            <ValidationMessage For="() => hiringMsg.Subject" />
        </div>
        <div class="form-group">
            <label>Message</label>
            <InputTextArea @bind-Value="hiringMsg.Message" class="form-control" rows="5" placeholder="Tell me about the opportunity... (optional)" />
        </div>
        <button type="submit" class="btn-primary btn-full">Send Message →</button>
    </EditForm>
}

@code {
    HiringMessage hiringMsg = new();
    bool messageSent;

    async Task SendMessage()
    {
        hiringMsg.SentAt = DateTime.UtcNow;
        await Svc.AddMessageAsync(hiringMsg);
        messageSent = true;
        hiringMsg = new();
    }
}
