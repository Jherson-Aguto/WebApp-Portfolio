@rendermode InteractiveServer
@inject ContentService Svc

@if (collabSent)
{
    <div class="alert-success">
        <span class="alert-icon"><Icon Name="check-circle" Size="22" /></span>
        <div>
            <strong>Request sent!</strong>
            <p>Thanks for reaching out. I'll review your request and get back to you.</p>
        </div>
    </div>
}
else
{
    <EditForm Model="collabReq" OnValidSubmit="SendCollabRequest" class="contact-form">
        <DataAnnotationsValidator />
        <ValidationSummary class="validation-summary" />
        <div class="form-row">
            <div class="form-group">
                <label>First Name *</label>
                <InputText @bind-Value="collabReq.FirstName" class="form-control" placeholder="Jane" />
                <ValidationMessage For="() => collabReq.FirstName" />
            </div>
            <div class="form-group">
                <label>Last Name *</label>
                <InputText @bind-Value="collabReq.LastName" class="form-control" placeholder="Doe" />
                <ValidationMessage For="() => collabReq.LastName" />
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>Email</label>
                <InputText @bind-Value="collabReq.Email" class="form-control" placeholder="jane@example.com (optional)" />
                <ValidationMessage For="() => collabReq.Email" />
            </div>
            <div class="form-group">
                <label>Portfolio URL</label>
                <InputText @bind-Value="collabReq.PortfolioUrl" class="form-control" placeholder="https://yoursite.com (optional)" />
                <ValidationMessage For="() => collabReq.PortfolioUrl" />
            </div>
        </div>
        <div class="form-group">
            <label>Collaboration Idea <span class="field-hint">(max 500 chars)</span></label>
            <InputTextArea @bind-Value="collabReq.Message" class="form-control" rows="4"
                           placeholder="E.g. Let's build a C# project together, or I'd love to learn about your Blazor setup!" />
            <span class="input-description">Briefly describe your project or how we can work together.</span>
            <ValidationMessage For="() => collabReq.Message" />
        </div>
        <button type="submit" class="btn-primary btn-full">Send Collaboration Request →</button>
    </EditForm>
}

@code {
    CollaborationRequest collabReq = new();
    bool collabSent;

    async Task SendCollabRequest()
    {
        await Svc.AddCollaborationRequestAsync(collabReq);
        collabSent = true;
        collabReq = new();
    }
}
