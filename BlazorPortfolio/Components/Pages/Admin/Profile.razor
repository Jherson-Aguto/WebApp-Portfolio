@page "/admin/profile"
@layout AdminLayout
@rendermode InteractiveServer
@inject ContentService Svc
@inject CacheService Cache
@inject CloudinaryService Cloudinary

<PageTitle>Edit Profile</PageTitle>
<h1>Profile</h1>

@if (profile is null)
{
    <p>Loading...</p>
}
else
{
    <EditForm Model="profile" OnValidSubmit="Save" class="edit-form" style="max-width:700px">
        <DataAnnotationsValidator />

        @if (!string.IsNullOrEmpty(successMsg))
        {
            <div class="alert-success" style="margin-bottom:1rem">
                <span class="alert-icon">✅</span>
                <div><strong>@successMsg</strong></div>
            </div>
        }
        @if (!string.IsNullOrEmpty(errorMsg))
        {
            <div class="alert-error">@errorMsg</div>
        }

        <h3>Hero Content</h3>
        <div class="form-group">
            <label>Owner Name *</label>
            <InputText @bind-Value="profile.OwnerName" class="form-control" />
            <ValidationMessage For="() => profile.OwnerName" />
        </div>
        <div class="form-group">
            <label>Eyebrow Text</label>
            <InputText @bind-Value="profile.Eyebrow" class="form-control" />
        </div>
        <div class="form-group">
            <label>Tagline</label>
            <InputText @bind-Value="profile.Tagline" class="form-control" />
        </div>
        <div class="form-group">
            <label>Bio</label>
            <InputTextArea @bind-Value="profile.HeroBio" class="form-control" rows="4" />
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>Primary CTA Label</label>
                <InputText @bind-Value="profile.HeroCta" class="form-control" />
            </div>
            <div class="form-group">
                <label>Secondary CTA Label</label>
                <InputText @bind-Value="profile.HeroSecondaryCta" class="form-control" />
            </div>
        </div>

        <h3 style="margin-top:1.5rem">Contact Info</h3>
        <div class="form-row">
            <div class="form-group">
                <label>Email</label>
                <InputText @bind-Value="profile.Email" class="form-control" />
            </div>
            <div class="form-group">
                <label>Location</label>
                <InputText @bind-Value="profile.Location" class="form-control" />
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>GitHub URL</label>
                <InputText @bind-Value="profile.GitHubUrl" class="form-control" />
            </div>
            <div class="form-group">
                <label>LinkedIn URL</label>
                <InputText @bind-Value="profile.LinkedInUrl" class="form-control" />
            </div>
        </div>
        <div class="form-group">
            <label>GitHub Username (for auto-sync of pinned repos &amp; activity)</label>
            <InputText @bind-Value="profile.GitHubUsername" class="form-control" placeholder="e.g. octocat" />
            <small style="color:var(--text-muted)">Set GitHub:Token in appsettings.json to enable pinned repos &amp; contribution graph.</small>
        </div>
        <div class="form-group">
            <label>Resume URL (Google Drive PDF link)</label>
            <InputText @bind-Value="profile.ResumeUrl" class="form-control" placeholder="https://drive.google.com/file/d/..." />
            <small style="color:var(--text-muted)">Paste your Google Drive shareable link. A "Resume" button will appear in the hero.</small>
        </div>

        <button type="submit" class="btn-primary">Save Profile</button>
        <button type="button" class="btn-secondary" @onclick="ClearGitHubCache" style="margin-left:.5rem">↺ Refresh GitHub Data</button>
    </EditForm>

    <div class="edit-form" style="max-width:700px;margin-top:1.5rem">
        <h3>Profile Picture</h3>
        @if (!string.IsNullOrEmpty(uploadError))
        {
            <div class="alert-error">@uploadError</div>
        }
        @if (!string.IsNullOrEmpty(uploadSuccess))
        {
            <div class="alert-success" style="margin-bottom:1rem">
                <span class="alert-icon">✅</span>
                <div><strong>@uploadSuccess</strong></div>
            </div>
        }

        @if (Cloudinary.IsConfigured)
        {
            <!-- Direct upload to Cloudinary -->
            <div class="form-group" style="margin-top:1rem">
                <label>Upload Image (JPEG, PNG, WebP — max 5 MB)</label>
                <InputFile OnChange="HandleUpload" accept="image/jpeg,image/png,image/webp"
                           class="form-control" disabled="@uploading" />
            </div>
            @if (uploading)
            {
                <p style="color:var(--text-muted);margin-top:.5rem">⏳ Uploading to Cloudinary...</p>
            }
        }
        else
        {
            <!-- Fallback: manual URL paste -->
            <p style="color:var(--text-muted);font-size:.875rem">
                Cloudinary is not configured. Set <code>Cloudinary:CloudName</code>, <code>ApiKey</code>,
                and <code>ApiSecret</code> in your environment variables, or paste a URL manually below.
            </p>
            <div class="form-group" style="margin-top:1rem">
                <label>Avatar URL</label>
                <InputText @bind-Value="avatarUrlInput" class="form-control"
                           placeholder="https://res.cloudinary.com/your-cloud/image/upload/v1/avatar.jpg" />
            </div>
            <button type="button" class="btn-primary" style="margin-top:.5rem" @onclick="SaveAvatarUrl">Save URL</button>
        }

        @if (!string.IsNullOrEmpty(profile.AvatarUrl))
        {
            <img src="@profile.AvatarUrl" alt="Current avatar" class="avatar-preview" style="margin-top:1rem" />
        }
    </div>
}

@code {
    SiteProfile? profile;
    string? successMsg;
    string? errorMsg;
    string? uploadError;
    string? uploadSuccess;
    string avatarUrlInput = "";
    bool uploading;

    protected override async Task OnInitializedAsync()
    {
        profile = await Svc.GetProfileAsync();
        avatarUrlInput = profile.AvatarUrl ?? "";
    }

    async Task Save()
    {
        if (string.IsNullOrWhiteSpace(profile!.OwnerName))
        {
            errorMsg = "Owner Name is required.";
            return;
        }
        errorMsg = null;
        await Svc.SaveProfileAsync(profile);
        await Cache.RemoveAsync(CacheService.Keys.Profile);
        successMsg = "Profile saved successfully.";
    }

    async Task ClearGitHubCache()
    {
        await Cache.RemoveAsync(CacheService.Keys.GitHubProfile);
        await Cache.RemoveAsync(CacheService.Keys.GitHubPinned);
        await Cache.RemoveAsync(CacheService.Keys.GitHubContributions);
        successMsg = "GitHub cache cleared — data will refresh on next page load.";
    }

    async Task HandleUpload(InputFileChangeEventArgs e)
    {
        uploadError = null;
        uploadSuccess = null;
        uploading = true;

        var file = e.File;
        var allowed = new[] { "image/jpeg", "image/png", "image/webp" };

        if (!allowed.Contains(file.ContentType))
        {
            uploadError = "Only JPEG, PNG, and WebP images are allowed.";
            uploading = false;
            return;
        }
        const long maxSize = 5 * 1024 * 1024;
        if (file.Size > maxSize)
        {
            uploadError = "File must be 5 MB or smaller.";
            uploading = false;
            return;
        }

        try
        {
            await using var stream = file.OpenReadStream(maxSize);
            var url = await Cloudinary.UploadAsync(stream, file.Name);

            profile!.AvatarUrl = url;
            await Svc.SaveProfileAsync(profile);
            await Cache.RemoveAsync(CacheService.Keys.Profile);
            uploadSuccess = "Image uploaded to Cloudinary and saved.";
        }
        catch (Exception ex)
        {
            uploadError = $"Upload failed: {ex.Message}";
        }
        finally
        {
            uploading = false;
        }
    }

    async Task SaveAvatarUrl()
    {
        uploadError = null;
        uploadSuccess = null;

        if (string.IsNullOrWhiteSpace(avatarUrlInput) ||
            !Uri.TryCreate(avatarUrlInput.Trim(), UriKind.Absolute, out var uri) ||
            (uri.Scheme != Uri.UriSchemeHttps && uri.Scheme != Uri.UriSchemeHttp))
        {
            uploadError = "Please enter a valid image URL (http/https).";
            return;
        }

        profile!.AvatarUrl = avatarUrlInput.Trim();
        await Svc.SaveProfileAsync(profile);
        await Cache.RemoveAsync(CacheService.Keys.Profile);
        uploadSuccess = "Avatar URL saved.";
    }
}
